    </body>

    <!-- ==================== LEFT HAND ==================== -->

    <body name="l_thumbKnuckle" mocap="true">
      <geom type="sphere" size="0.008" rgba="0.4 0.6 0.9 1" contype="1" conaffinity="1"/>
    </body>
    <body name="l_thumbIntermediateBase" mocap="true">
      <geom type="sphere" size="0.007" rgba="0.4 0.6 0.9 1" contype="1" conaffinity="1"/>
    </body>
    <body name="l_thumbIntermediateTip" mocap="true">
