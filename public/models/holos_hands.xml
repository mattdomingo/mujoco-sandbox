    <!-- ==================== PRESSURE BALL ==================== -->
    <!-- A free rigid sphere that hands can physically push.
         Its position is purely MuJoCo output — we never write to it directly.
         Starts between where the hands typically meet. -->
    <body name="pressure_ball" pos="0 0.9 0.5">
      <freejoint name="ball_free"/>
      <geom name="ball_geom" type="sphere" size="0.04"
            rgba="0.2 0.5 1.0 0.85"
            contype="1" conaffinity="1"
            mass="0.05"/>
    </body>

  </worldbody>

</mujoco>
