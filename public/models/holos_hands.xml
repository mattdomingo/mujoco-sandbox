    </body>
    <body name="r_littleFingerKnuckle" mocap="true">
      <geom type="sphere" size="0.008" rgba="0.9 0.6 0.4 1" contype="1" conaffinity="1"/>
    </body>
    <body name="r_littleFingerIntermediateBase" mocap="true">
      <geom type="sphere" size="0.007" rgba="0.9 0.6 0.4 1" contype="1" conaffinity="1"/>
    </body>
    <body name="r_littleFingerIntermediateTip" mocap="true">
      <geom type="sphere" size="0.007" rgba="0.9 0.6 0.4 1" contype="1" conaffinity="1"/>
